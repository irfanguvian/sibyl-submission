# NOTE: docker-compose.yml is fully hardcoded and does NOT read this file.
# These values mirror the hardcoded compose config and are only used for
# running services directly on the host (e.g. `pnpm dev`). Keep them in sync
# with docker-compose.yml.

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=tuition
POSTGRES_PASSWORD=tuition_password
POSTGRES_DB=tuitiondb
# Host port published by the `db` service in docker-compose.yml
POSTGRES_PORT=5444

POSTGRES_TEST_DB=tuition_test
# Host port published by the `db_test` service in docker-compose.yml
POSTGRES_TEST_PORT=5435

# ── API ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
API_PORT=3001
# Allowed browser origins for CORS (comma-separated). Covers the frontend on
# its default and remapped dev ports.
CORS_ORIGINS=http://localhost:3000,http://localhost:3010

# ── Web ───────────────────────────────────────────────────────────────────────
# Browser-facing API base (public)
NEXT_PUBLIC_API_URL=http://localhost:3001
# Server-side BFF base (Next server → backend).
# Running the full stack via `docker compose`: use the compose-network host below.
# Running the frontend on the host (`pnpm dev`): override to http://localhost:3001
BACKEND_URL=http://backend:3001
# Host port published by the `frontend` service in docker-compose.yml
WEB_PORT=3010

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=documents
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# Server-side S3 endpoint the backend uses to store objects. On the compose
# network this is the service host; for host-dev use http://localhost:9000.
S3_ENDPOINT=http://minio:9000
# Browser-reachable endpoint used to sign download URLs (must NOT be the
# compose-internal host). Leave unset for host-dev / cloud (defaults to S3_ENDPOINT).
S3_PUBLIC_ENDPOINT=http://localhost:9000

# ════════════════════════════════════════════════════════════════════════════
# PRODUCTION — Railway single container + external Postgres + Cloudflare R2
# ════════════════════════════════════════════════════════════════════════════
# Set these as Railway service variables (NOT committed). The combined image
# (root Dockerfile) runs Next.js on $PORT (public) and NestJS on 127.0.0.1:3001
# (internal). Railway injects PORT automatically — do NOT set it yourself.
#
# ── Postgres (Railway managed or external) ──
#   DATABASE_URL=postgresql://USER:PASS@HOST:PORT/DB
#   DATABASE_DIRECT_URL=postgresql://USER:PASS@HOST:PORT/DB   # same value; schema requires it
#   JWT_SECRET=<64+ char random string>
#   NODE_ENV=production
#   CORS_ORIGINS=https://YOUR-APP.up.railway.app
#
# ── Frontend → backend over localhost (inside the one container) ──
#   BACKEND_URL=http://127.0.0.1:3001
#   # NEXT_PUBLIC_API_URL is unused (browser talks to Next only) — leave unset.
#
# ── Object storage: Cloudflare R2 (S3-compatible, drop-in for MinIO) ──
#   S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#   # R2 account endpoint is browser-reachable, so the presign split is not
#   # needed — leave S3_PUBLIC_ENDPOINT UNSET (defaults to S3_ENDPOINT).
#   S3_REGION=auto
#   S3_BUCKET=documents
#   S3_ACCESS_KEY=<R2 access key id>
#   S3_SECRET_KEY=<R2 secret access key>
#   S3_FORCE_PATH_STYLE=true
