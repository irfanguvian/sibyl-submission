# Backend base URL as seen from the Next.js server (BFF). Not exposed to the browser.
# Local dev default; in Docker compose use http://backend:3001.
BACKEND_URL=http://localhost:3001

# Browser-facing API URL, used only for display. Optional.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Demo mode: when "true", the login page shows one-click "Sign in as Parent" /
# "Sign in as Tutor" buttons using the seeded demo accounts, for manual testing
# in a deployed environment. Leave unset/false in real production.
NEXT_PUBLIC_DEMO_MODE=false
