# PostgreSQL connection string (required)
# Matches the hardcoded `db` service in docker-compose.yml (host port 5444).
DATABASE_URL=postgresql://tuition:tuition_password@localhost:5444/tuitiondb

# Direct connection URL for Prisma migrations (e.g. bypasses PgBouncer)
DATABASE_DIRECT_URL=postgresql://tuition:tuition_password@localhost:5444/tuitiondb

# JWT signing secret (required, keep long and random in production)
JWT_SECRET=change-me-to-a-long-random-secret

# Server port (default: 3001)
PORT=3001

# Runtime environment
NODE_ENV=development

# Token lifetimes in seconds (defaults: access 15m, refresh 7d)
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=604800

# Comma-separated CORS allowlist (frontend origin)
CORS_ORIGINS=http://localhost:3000,http://localhost:3010
